    {
      "title": "Meta 페이지 엑세스 승인 가이드_EN",
      "excerpt": "[Video Guide]",
      "excerptMedia": [
        {
          "url": "/uploads/1779092186417-ljf3-page_guide_en_01.mp4",
          "name": "page_guide_en_01.mp4",
          "type": "video",
          "size": 10827832,
          "width": null,
          "height": null
        }
      ],
      "steps": [
        {
          "text": "Only users who are the fan page creator or have admin permissions can proceed.\n- Go to the page -> Click 'Settings' under 'Manage Fan Page'.",
          "media": [
            {
              "url": "/uploads/1779093007745-ekr9-page_en_01-878x420.JPEG",
              "name": "page_en_01-878x420.JPEG",
              "type": "image",
              "size": 118382,
              "width": null,
              "height": null
            }
          ]
        },
        {
          "text": "- Click 'Page Settings' in Settings & Privacy.",
          "media": [
            {
              "url": "/uploads/1779093011773-r9nk-page_en_02-878x420.JPEG",
              "name": "page_en_02-878x420.JPEG",
              "type": "image",
              "size": 95795,
              "width": null,
              "height": null
            }
          ]
        },
        {
          "text": "- Click 'Page Access' in Page Settings.",
          "media": [
            {
              "url": "/uploads/1779093016366-bh07-page_en_03-893x420.JPEG",
              "name": "page_en_03-893x420.JPEG",
              "type": "image",
              "size": 108655,
              "width": null,
              "height": null
            }
          ]
        },
        {
          "text": "- Check 'Pending Access Requests' under Partners with Access.\n\n- Click 'Review Request' for Nasmedia.",
          "media": [
            {
              "url": "/uploads/1779093020950-zeyp-page_en_04-878x420.JPEG",
              "name": "page_en_04-878x420.JPEG",
              "type": "image",
              "size": 111505,
              "width": null,
              "height": null
            }
          ]
        },
        {
          "text": "- Click 'Next' on the Page Access Request screen.",
          "media": [
            {
              "url": "/uploads/1779093025754-auah-page_en_05-878x420.JPEG",
              "name": "page_en_05-878x420.JPEG",
              "type": "image",
              "size": 84818,
              "width": null,
              "height": null
            }
          ]
        },
        {
          "text": "- Click 'Approve' (또는 'Accept') on the Page Access Request screen.",
          "media": [
            {
              "url": "/uploads/1779093030470-t834-page_en_06-878x420.JPEG",
              "name": "page_en_06-878x420.JPEG",
              "type": "image",
              "size": 84953,
              "width": null,
              "height": null
            }
          ]
        },
        {
          "text": "- Enter your password to grant page access, then click 'Confirm'.",
          "media": [
            {
              "url": "/uploads/1779093035553-c74s-page_en_07-877x420.JPEG",
              "name": "page_en_07-877x420.JPEG",
              "type": "image",
              "size": 72826,
              "width": null,
              "height": null
            }
          ]
        },
        {
          "text": "- Page access granted.",
          "media": [
            {
              "url": "/uploads/1779093039570-0zk7-page_en_08-878x420.JPEG",
              "name": "page_en_08-878x420.JPEG",
              "type": "image",
              "size": 110917,
              "width": null,
              "height": null
            }
          ]
        }
      ],
      "media": [],
      "id": 1779092440308,
      "date": "2026-05-18",
      "views": 0
    },
