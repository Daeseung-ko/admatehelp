      "date": "2025-11-15",
      "views": 2180,
      "media": [],
      "steps": [
        {
          "text": "- 파트너 할당을 하려고 하는 팬페이지를 선택합니다.",
          "media": [
            {
              "url": "/uploads/1779426297131-biqp-pt_01-835x420.JPEG",
              "name": "pt_01-835x420.JPEG",
              "type": "image",
